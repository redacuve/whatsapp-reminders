# WhatsApp Bot Configuration
# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will NOT be committed

# Your WhatsApp number (format: country_code + number + @c.us)
MY_NUMBER=1234567890@c.us

# Your WhatsApp LID (appears in msg.from when you receive messages)
MY_NUMBER_LID=000000000000000@lid

# WhatsApp group ID (optional, leave empty to disable group features)
MY_GROUP=

# Default language for responses
DEFAULT_LOCALE=
